{
  "name": "placepulse-sentiment-console",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:migrate": "tsx --env-file-if-exists=.env.local scripts/migrate.ts",
    "import:sentiment": "tsx --env-file-if-exists=.env.local scripts/import-sentiment-data.ts",
    "evals": "NODE_OPTIONS='--conditions=react-server' tsx --env-file-if-exists=.env.local scripts/run-evals.ts",
    "ci": "npm run typecheck && npm run lint && npm run build"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.69",
    "@ai-sdk/react": "^3.0.201",
    "@neondatabase/serverless": "^1.1.0",
    "@react-pdf/renderer": "^4.5.1",
    "@terraformer/wkt": "^2.2.1",
    "@turf/turf": "^7.3.5",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.4.0",
    "@vercel/speed-insights": "^2.0.0",
    "ai": "^6.0.199",
    "apexcharts": "^5.14.0",
    "csv-parse": "^6.2.1",
    "dayjs": "^1.11.21",
    "echarts": "^6.1.0",
    "echarts-for-react": "^3.0.6",
    "flowbite-react": "^0.12.17",
    "lucide-react": "^1.17.0",
    "mapbox-gl": "^3.24.0",
    "nanoid": "^5.1.11",
    "next": "16.2.9",
    "pg": "^8.21.0",
    "pg-copy-streams": "^7.0.0",
    "react": "19.2.4",
    "react-apexcharts": "^2.1.0",
    "react-dom": "19.2.4",
    "react-icons": "^5.6.0",
    "recharts": "^3.8.1",
    "server-only": "^0.0.1",
    "streamdown": "^2.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/pg-copy-streams": "^1.2.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
