NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_ENABLE_ARCHITECTURE_PANEL=true

DATABASE_URL=

# Vercel AI Gateway key for the assistant and brief models. On Vercel this is provided
# automatically via the project OIDC token; set it only for local development.
# Get one from: Vercel dashboard -> AI Gateway -> API keys.
AI_GATEWAY_API_KEY=

EVALS_REQUIRE_PASS=false

# Langfuse AI observability (optional). When both keys are set, every assistant turn, brief draft and
# thread-title call is traced to Langfuse over OpenTelemetry, grouped by conversation thread, down to
# each tool call. Leave blank to disable tracing with no behaviour change. Keys: Langfuse project
# settings. Host defaults to cloud.langfuse.com; use https://us.cloud.langfuse.com for the US region.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com