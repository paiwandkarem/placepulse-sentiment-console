NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_ENABLE_ARCHITECTURE_PANEL=true

DATABASE_URL=

# Vercel AI Gateway key for the assistant and brief models. On Vercel this is provided
# automatically via the project OIDC token; set it only for local development.
# Get one from: Vercel dashboard -> AI Gateway -> API keys.
AI_GATEWAY_API_KEY=

EVALS_REQUIRE_PASS=false