# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# editor
.vscode/

# flowbite-react generated output
.flowbite-react/

# suburb boundary GeoJSON: 5.4 MB, hosted on Vercel Blob, not committed
# (NEXT_PUBLIC_SUBURB_GEOJSON_URL points at the Blob copy)
public/qld-suburbs.geojson

# internal working notes and prep material, kept locally, not part of the shipped repo
/docs/
